{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "src/ExamPaper.Core/**/*.csproj",
            "src/ExamPaper.Infrastructure/**/*.csproj",
            "src/ExamPaper.Service/**/*.csproj"
          ],
          "exclude": [
            "**/obj/**",
            "**/bin/**"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**",
          "obj/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "**/assets/**",
          "images/**"
        ],
        "exclude": [
          "**/*.md",
          "**/*.yml",
          "**/obj/**",
          "**/_site/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "ExamPaper",
      "_appTitle": "ExamPaper",
      "_enableSearch": true,
      "pdf": true
    }
  }
}