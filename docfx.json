{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "ExamPaper.Core/**/*.csproj",
            "ExamPaper.Infrastructure/**/*.csproj",
            "ExamPaper.Service/**/*.csproj"
          ],
          "exclude": [
            "**/obj/**",
            "**/bin/**"
          ]
        }
      ],
      "dest": "api",
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "docs/**/*.md",
          "README.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "docs/assets/**"
        ]
      }
    ],
    "dest": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default"
    ],
    "postProcessors": [],
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false
  }
}
